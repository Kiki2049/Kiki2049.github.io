    <title>first code</title>
    <url>/2019/12/28/first-code/</url>
    <content><![CDATA[<p>尝试下怎么加代码块的wmm</p>
<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">#include &lt;cstdio&gt;</span></pre></td></tr><tr><td class="code"><pre><span class="line">#include &lt;iostream&gt;</span></pre></td></tr><tr><td class="code"><pre><span class="line">#include &lt;algorithm&gt;</span></pre></td></tr><tr><td class="code"><pre><span class="line">#include &lt;cstring&gt;</span></pre></td></tr><tr><td class="code"><pre><span class="line">using namespace std;</span></pre></td></tr><tr><td class="code"><pre><span class="line"></span></pre></td></tr><tr><td class="code"><pre><span class="line">struct student &#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	char name[15];</span></pre></td></tr><tr><td class="code"><pre><span class="line">	int sum;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	int en;</span></pre></td></tr><tr><td class="code"><pre><span class="line">&#125;;</span></pre></td></tr><tr><td class="code"><pre><span class="line">student a[205];</span></pre></td></tr><tr><td class="code"><pre><span class="line"></span></pre></td></tr><tr><td class="code"><pre><span class="line">int cmp(const student&amp; first, const student&amp; second)</span></pre></td></tr><tr><td class="code"><pre><span class="line">&#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	if (first.sum &lt; second.sum) return 0;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	else if (first.sum &gt; second.sum) return 1;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	else &#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">		if (first.en &lt; second.en) return 0;</span></pre></td></tr><tr><td class="code"><pre><span class="line">		else if (first.en &gt; second.en) return 1;</span></pre></td></tr><tr><td class="code"><pre><span class="line">		else &#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">			return strcmp(first.name, second.name) &lt; 0;</span></pre></td></tr><tr><td class="code"><pre><span class="line">			&#125;</span></pre></td></tr><tr><td class="code"><pre><span class="line">		&#125;</span></pre></td></tr><tr><td class="code"><pre><span class="line">&#125;</span></pre></td></tr><tr><td class="code"><pre><span class="line"></span></pre></td></tr><tr><td class="code"><pre><span class="line"></span></pre></td></tr><tr><td class="code"><pre><span class="line">int main()</span></pre></td></tr><tr><td class="code"><pre><span class="line">&#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	int m, n;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	scanf(&quot;%d %d&quot;, &amp;m, &amp;n);</span></pre></td></tr><tr><td class="code"><pre><span class="line">	for (int i &#x3D; 0; i &lt; m; i++) &#123;</span></pre></td></tr><tr><td class="code"><pre><span class="line">		scanf(&quot;%s %d %d&quot;, a[i].name, &amp;a[i].sum, &amp;a[i].en);</span></pre></td></tr><tr><td class="code"><pre><span class="line">	&#125;</span></pre></td></tr><tr><td class="code"><pre><span class="line">	sort(a, a + m, cmp);</span></pre></td></tr><tr><td class="code"><pre><span class="line">	for (int i &#x3D; 0; i &lt; n; i++)</span></pre></td></tr><tr><td class="code"><pre><span class="line">		printf(&quot;%s %d %d\n&quot;, a[i].name, a[i].sum, a[i].en);</span></pre></td></tr><tr><td class="code"><pre><span class="line">	return 0;</span></pre></td></tr><tr><td class="code"><pre><span class="line">&#125;</span></pre></td></tr></table></figure>
]]></content>
